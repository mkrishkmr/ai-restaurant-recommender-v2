# ==========================================
# ENV Variables for Bangalore Recommender
# ==========================================

# -------------------------
# AI Core Engine
# -------------------------
# Required: Valid Gemini API Key from Google AI Studio / Vertex AI
# Used for Intent Parsing, State Mutation, and Vibe Summarization
GEMINI_API_KEY="your_gemini_api_key_here"

# -------------------------
# Database & Auth (Supabase)
# -------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Keep this secret! Used tightly in backend API routes for admin-level operations.
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# -------------------------
# App Configuration
# -------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
